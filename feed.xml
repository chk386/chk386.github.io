t</span> sameTileCount =<span class="number">3</span>;</div><div class="line"></div><div class="line">        <span class="function"><span class="keyword">public</span> <span class="title">AnyPungGame</span><span class="params">(<span class="keyword">int</span>[][] in)</span> </span>&#123;</div><div class="line">            <span class="keyword">this</span>.input = in;</div><div class="line">            <span class="keyword">this</span>.xLength = input[<span class="number">0</span>].length;</div><div class="line">            <span class="keyword">this</span>.yLength = input.length;</div><div class="line">        &#125;</div><div class="line"></div><div class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">void</span> <span class="title">start</span><span class="params">()</span> </span>&#123;</div><div class="line">            System.out.println(<span class="string">"input"</span>);</div><div class="line">            print();</div><div class="line">            </div><div class="line">            <span class="comment">// нГАмЭЉмЭД м†Ьк±∞ нХ†мИШ мЧЖмЭДлЦД кєМмІА лђінХЬ л£®нФД!</span></div><div class="line">            <span class="keyword">while</span>(<span class="keyword">true</span>) &#123;</div><div class="line">                <span class="keyword">boolean</span> isMovableTiles = checkEmptyTiles();</div><div class="line">                <span class="keyword">boolean</span> isSameTiles = <span class="keyword">true</span>;</div><div class="line"></div><div class="line">                <span class="keyword">if</span>(!isMovableTiles) &#123;</div><div class="line">                    isSameTiles = checkSameTiles();</div><div class="line">                &#125;</div><div class="line"></div><div class="line">                <span class="keyword">if</span>(!isMovableTiles &amp;&amp; !isSameTiles) </div><div class="line">                    <span class="keyword">break</span>;</div><div class="line">            &#125;</div><div class="line"></div><div class="line">            System.out.println(<span class="string">"result"</span>);</div><div class="line">            print();</div><div class="line">        &#125;</div><div class="line"></div><div class="line">        <span class="comment">// лєИ нГАмЭЉмЭі мГЭкЄ∞л©і мЬДмЧР нГАмЭЉмЭД мХДлЮШл°Ь мЭілПЩ</span></div><div class="line">        <span class="function"><span class="keyword">private</span> <span class="keyword">boolean</span> <span class="title">checkEmptyTiles</span><span class="params">()</span> </span>&#123;</div><div class="line">            <span class="keyword">for</span>(<span class="keyword">int</span> y=<span class="number">0</span>; y&lt;<span class="keyword">this</span>.yLength; y++) &#123;</div><div class="line">                <span class="keyword">for</span>(<span class="keyword">int</span> x=<span class="number">0</span>; x&lt;<span class="keyword">this</span>.xLength; x++) &#123;</div><div class="line">                    <span class="comment">// лєИк≥µк∞Д нГАмЭЉ лВіл¶ђкЄ∞</span></div><div class="line">                    <span class="keyword">int</span> currentValue = input[y][x];</div><div class="line"></div><div class="line">                    <span class="comment">// м≤Ђл≤ИмІЄм§ДмЭі мХДлЛИк≥† 0мЭіл©імДЬ мЬДм™љ л∞∞мЧімЭі 0мЭі мХДлЛРк≤љмЪ∞</span></div><div class="line">                    <span class="keyword">if</span>(y != <span class="number">0</span> &amp;&amp; currentValue == <span class="number">0</span> &amp;&amp; input[y-<span class="number">1</span>][x] != <span class="number">0</span>) &#123;</div><div class="line">                        <span class="keyword">for</span>(<span class="keyword">int</span> start = y; start&gt;<span class="number">0</span>; start--) &#123;</div><div class="line">                            input[start][x] = input[start-<span class="number">1</span>][x];</div><div class="line">                        &#125;</div><div class="line"></div><div class="line">                        <span class="comment">//м≤Ђл≤ИмІЄ нЦЙмЭА лђім°∞к±і 0</span></div><div class="line">                        input[<span class="number">0</span>][x] = <span class="number">0</span>;</div><div class="line">                        System.out.println(<span class="string">"move down"</span>);</div><div class="line">                        print();</div><div class="line">                        </div><div class="line">                        <span class="keyword">return</span> <span class="keyword">true</span>;</div><div class="line">                    &#125;</div><div class="line">                &#125;</div><div class="line">            &#125;</div><div class="line"></div><div class="line">            <span class="keyword">return</span> <span class="keyword">false</span>;</div><div class="line">        &#125;</div><div class="line"></div><div class="line">        <span class="comment">// нГАмЭЉнМРмЭД мИЬм∞®лМАл°Ь нГРмГЙнХШмЧђ к∞ЩмЭА л™®мЦСмЭШ нГАмЭЉмЭД мВ≠м†ЬнХЬлЛ§.</span></div><div class="line">        <span class="function"><span class="keyword">private</span> <span class="keyword">boolean</span> <span class="title">checkSameTiles</span><span class="params">()</span> </span>&#123;</div><div class="line">            <span class="keyword">for</span>(<span class="keyword">int</span> y=<span class="number">0</span>; y&lt;<span class="keyword">this</span>.yLength; y++) &#123;</div><div class="line">                <span class="keyword">for</span>(<span class="keyword">int</span> x=<span class="number">0</span>; x&lt;<span class="keyword">this</span>.xLength; x++) &#123;</div><div class="line">                    <span class="keyword">if</span>(input[y][x] == <span class="number">0</span>) &#123;</div><div class="line">                        <span class="keyword">continue</span>;</div><div class="line">                    &#125;</div><div class="line"></div><div class="line">                    <span class="keyword">for</span>(<span class="keyword">int</span>[] range : <span class="keyword">this</span>.ranges) &#123;</div><div class="line">                        <span class="keyword">if</span>(validByRange(x, y, range) &amp;&amp; removeSameTiles(x, y, range)) &#123;</div><div class="line">                            System.out.println(<span class="string">"remove tiles"</span>);</div><div class="line">                            print();</div><div class="line"></div><div class="line">                            <span class="keyword">return</span> <span class="keyword">true</span>;</div><div class="line">                        &#125;</div><div class="line">                    &#125;</div><div class="line">                &#125;</div><div class="line">            &#125;</div><div class="line"></div><div class="line">            <span class="keyword">return</span> <span class="keyword">false</span>;</div><div class="line">        &#125;</div><div class="line"></div><div class="line">        <span class="comment">// к∞ЩмЭА л™®мЦСмЭШ нГАмЭЉмЭД мІАмЪілЛ§.</span></div><div class="line">        <span class="function"><span class="keyword">private</span> <span class="keyword">boolean</span> <span class="title">removeSameTiles</span><span class="params">(<span class="keyword">int</span> x, <span class="keyword">int</span> y, <span class="keyword">int</span>[] range)</span> </span>&#123;</div><div class="line">            <span class="keyword">int</span>[][] movableMap = getMovableMap(x, y, range);</div><div class="line"></div><div class="line">            <span class="keyword">int</span> currentValue = input[y][x];</div><div class="line"></div><div class="line">            <span class="keyword">for</span>(<span class="keyword">int</span> i=<span class="number">0</span>; i&lt;movableMap.length; i++) &#123;</div><div class="line">                <span class="keyword">int</span>[] map = movableMap[i];</div><div class="line">                <span class="keyword">if</span>(currentValue != input[map[<span class="number">0</span>]][map[<span class="number">1</span>]]) &#123;</div><div class="line">                    <span class="keyword">return</span> <span class="keyword">false</span>;</div><div class="line">                &#125;</div><div class="line">            &#125;</div><div class="line"></div><div class="line">            <span class="comment">// нГАмЭЉмЭД мЧЖмХ§лЛ§.</span></div><div class="line">            <span class="keyword">for</span>(<span class="keyword">int</span> i=<span class="number">0</span>; i&lt;movableMap.length; i++) &#123;</div><div class="line">                <span class="keyword">int</span>[] map = movableMap[i];</div><div class="line"></div><div class="line">                input[map[<span class="number">0</span>]][map[<span class="number">1</span>]] = EMPTY;</div><div class="line">            &#125;</div><div class="line">            </div><div class="line">            <span class="keyword">return</span> <span class="keyword">true</span>;</div><div class="line">        &#125;</div><div class="line"></div><div class="line">        <span class="comment">// мЫАмІБмЭЉмИШ мЮИлКФ мҐМнСЬмЭШ л∞∞мЧімЭД кµђнХЬлЛ§.</span></div><div class="line">        <span class="comment">// todo: мҐАлНФ к∞ДлЛ®нХШк≤М нХ†мИШ мЮИмЭДкЇЉ к∞ЩмЭАлН∞.....</span></div><div class="line">        <span class="keyword">private</span> <span class="keyword">int</span>[][] getMovableMap(<span class="keyword">int</span> x, <span class="keyword">int</span> y, <span class="keyword">int</span>[] range) &#123;</div><div class="line">            <span class="keyword">int</span>[][] movableMap = <span class="keyword">new</span> <span class="keyword">int</span>[<span class="keyword">this</span>.sameTileCount][<span class="number">2</span>];</div><div class="line">            <span class="keyword">boolean</span> axisX = (range[<span class="number">0</span>] == <span class="number">0</span>);</div><div class="line">            <span class="keyword">int</span> move = axisX ? range[<span class="number">1</span>] : range[<span class="number">0</span>];</div><div class="line">            <span class="keyword">int</span> start, end, cnt = <span class="number">0</span>;</div><div class="line"></div><div class="line">            <span class="keyword">if</span>(axisX) &#123;</div><div class="line">                <span class="keyword">if</span>(move &lt; <span class="number">0</span>) &#123;</div><div class="line">                    start = x+move;</div><div class="line">                    end = x;</div><div class="line">                &#125;<span class="keyword">else</span> &#123;</div><div class="line">                    start = x;</div><div class="line">                    end = x+move;</div><div class="line">                &#125;</div><div class="line">                </div><div class="line">                <span class="keyword">for</span>(<span class="keyword">int</span> i = start; i&lt;=end; i++) &#123;    </div><div class="line">                    movableMap[cnt][<span class="number">0</span>] = y;</div><div class="line">                    movableMap[cnt][<span class="number">1</span>] = i;</div><div class="line">                    cnt++;</div><div class="line">                &#125;</div><div class="line"></div><div class="line">            &#125;<span class="keyword">else</span> &#123;</div><div class="line">                <span class="keyword">if</span>(move &lt; <span class="number">0</span>) &#123;</div><div class="line">                    start = y+move;</div><div class="line">                    end = y;</div><div class="line">                &#125;<span class="keyword">else</span> &#123;</div><div class="line">                    start = y;</div><div class="line">                    end = y+move;</div><div class="line">                &#125;</div><div class="line"></div><div class="line">                <span class="keyword">for</span>(<span class="keyword">int</span> i = start; i&lt;=end; i++) &#123;    </div><div class="line">                    movableMap[cnt][<span class="number">0</span>] = i;</div><div class="line">                    movableMap[cnt][<span class="number">1</span>] = x;</div><div class="line">                    cnt++;</div><div class="line">                &#125;</div><div class="line">            &#125;</div><div class="line"></div><div class="line">            <span class="keyword">return</span> movableMap;</div><div class="line">        &#125;</div><div class="line"></div><div class="line">        <span class="comment">// нГАмЭЉнМР л∞Фкє•мЬЉл°Ь лВШк∞АлКФмІА мЧђлґА</span></div><div class="line">        <span class="function"><span class="keyword">private</span> <span class="keyword">boolean</span> <span class="title">validByRange</span><span class="params">(<span class="keyword">int</span> x, <span class="keyword">int</span> y, <span class="keyword">int</span>[] range)</span> </span>&#123;</div><div class="line">            <span class="keyword">int</span> rangeX = x + range[<span class="number">1</span>];</div><div class="line">            <span class="keyword">int</span> rangeY = y + range[<span class="number">0</span>];</div><div class="line"></div><div class="line">            <span class="comment">// нШДмЮђ мҐМнСЬмЩА rangeл•Љ лНФнХімДЬ 0мЭімГБ лШРлКФ нГАмЭЉнМР кЄЄмЭіл≥ілЛ§ мЮСмХДмХЉнХЬлЛ§.</span></div><div class="line">            <span class="keyword">return</span> rangeX &gt;= <span class="number">0</span> &amp;&amp; rangeX &lt; <span class="keyword">this</span>.xLength &amp;&amp; rangeY &gt;=<span class="number">0</span> &amp;&amp; rangeY &lt; <span class="keyword">this</span>.yLength;</div><div class="line">        &#125;</div><div class="line"></div><div class="line">        <span class="function"><span class="keyword">private</span> <span class="keyword">void</span> <span class="title">print</span><span class="params">()</span> </span>&#123;</div><div class="line">            StringBuilder sb = <span class="keyword">new</span> StringBuilder();</div><div class="line">            <span class="keyword">for</span>(<span class="keyword">int</span>[] y : input) &#123;</div><div class="line">                <span class="keyword">for</span>(<span class="keyword">int</span> x : y) &#123;</div><div class="line">                    sb.append(x).append(SPACE);</div><div class="line">                &#125;</div><div class="line"></div><div class="line">                sb.append(NEW_LINE);</div><div class="line">            &#125;</div><div class="line"></div><div class="line">            System.out.println(sb.toString());</div><div class="line">        &#125;</div><div class="line">    &#125;</div><div class="line">&#125;</div></pre></td></tr></table></figure>]]></content>
    
